@startuml
title Diagrama de Casos de Uso - Sistema de Moeda Estudantil

left to right direction

'======================
' ATORES
'======================
actor Aluno
actor Professor
actor "Empresa Parceira" as Empresa
actor "Sistema (Automático)" as Sistema

'======================
' SISTEMA
'======================
rectangle "Sistema de Moeda Estudantil" {

  ' ALUNO
  usecase "Realizar Cadastro\n(Aluno)" as UC1
  usecase "Fazer Login" as UC2
  usecase "Consultar Extrato" as UC3
  usecase "Resgatar Vantagem" as UC4

  ' PROFESSOR
  usecase "Enviar Moedas" as UC5

  ' EMPRESA
  usecase "Realizar Cadastro\n(Empresa Parceira)" as UC6
  usecase "Cadastrar Vantagem" as UC7

  ' SISTEMA AUTOMÁTICO
  usecase "Notificar por Email" as UC8
  usecase "Gerar Cupom" as UC9
}

'======================
' RELACIONAMENTOS
'======================

Aluno --> UC1
Aluno --> UC2
Aluno --> UC3
Aluno --> UC4

Professor --> UC2
Professor --> UC3
Professor --> UC5

Empresa --> UC6
Empresa --> UC2
Empresa --> UC7

' Professor é pré-cadastrado pela instituição — sem UC1

' INCLUDE obrigatórios
UC5 ..> UC8 : <<include>>
UC4 ..> UC9 : <<include>>
UC4 ..> UC8 : <<include>>
UC6 ..> UC7 : <<include>>

' Sistema notifica empresa no resgate
Sistema --> UC8

@enduml