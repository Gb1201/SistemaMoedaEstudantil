@startuml
title Diagrama de Componentes - Sistema de Moeda Estudantil

'======================
' FRONT-END
'======================
package "Client Side (Front-end)" {
  component "Web App (React)" as ReactApp

  note right of ReactApp
    Telas: Login, Cadastro,
    Extrato, Envio de Moedas,
    Resgate de Vantagens
  end note
}

'======================
' BACK-END
'======================
package "Server Side (Back-end - MVC)" {

  component "API Controller (REST)" as API
  component "Auth / Security (JWT)" as Auth
  component "Service Layer\n(Regras de Negócio)" as Service
  component "Repository Layer\n(JPA / Hibernate)" as Repo

  API --> Auth : valida token
  API --> Service : delega requisições
  Service --> Repo : acessa dados
}

'======================
' SERVIÇO EXTERNO
'======================
package "Serviços Externos" {
  component "SMTP / Email Provider" as Email
}

Service --> Email : envia notificações\n(moedas recebidas, cupom)

'======================
' DATA LAYER
'======================
package "Data Layer" {
  database "PostgreSQL" as DB
}

'======================
' CONEXÕES ENTRE CAMADAS
'======================
ReactApp --> API : HTTP / JSON (REST)
Repo --> DB : CRUD / ORM

@enduml